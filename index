.nav-badge{font-family:var(--font-c);font-size:.6rem;font-weight:700;letter-spacing:.14em;background:rgba(212,0,0,.15);border:1px solid rgba(212,0,0,.35);color:var(--rb);padding:3px 8px;border-radius:4px;text-transform:uppercase;display:none;}
