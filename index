.cta-call{display:inline-flex;align-items:center;justify-content:center;gap:10px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.2);color:var(--w);font-family:var(--font-c);font-size:1rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase;padding:16px 32px;border-radius:4px;transition:all .25s;position:relative;overflow:hidden;min-width:200px;}
