nav{position:sticky;top:0;z-index:500;height:64px;background:rgba(6,6,6,.92);backdrop-filter:blur(20px);border-bottom:1px solid rgba(212,0,0,.2);display:flex;align-items:center;justify-content:space-between;padding:0 24px;transition:box-shadow .3s;}
