.hero-gradient{position:absolute;inset:0;z-index:1;background:radial-gradient(ellipse 90% 60% at 50% 100%,rgba(212,0,0,.18) 0%,transparent 70%),linear-gradient(180deg,rgba(6,6,6,.4) 0%,rgba(6,6,6,.0) 30%,rgba(6,6,6,.0) 60%,rgba(6,6,6,.95) 100%),linear-gradient(135deg,rgba(6,6,6,.6) 0%,transparent 50%);}
.hero-sweep{position:absolute;inset:0;z-index:1;pointer-events:none;background:linear-gradient(105deg,rgba(212,0,0,.06) 0%,transparent 40%,transparent 60%,rgba(212,0,0,.04) 100%);}
.hero-line{position:absolute;inset:0;z-index:2;pointer-events:none;overflow:hidden}
