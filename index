.nav-brand{display:flex;align-items:center;gap:12px}
.nav-logo{font-family:var(--font-d);font-size:1.8rem;letter-spacing:.06em;background:linear-gradient(135deg,#fff 0%,var(--chrome) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
