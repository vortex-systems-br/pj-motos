.nav-wa{background:var(--gr);color:#fff;font-family:var(--font-c);font-weight:800;font-size:.82rem;letter-spacing:.06em;padding:9px 18px;border-radius:50px;display:flex;align-items:center;gap:7px;transition:all .25s;position:relative;overflow:hidden;}
